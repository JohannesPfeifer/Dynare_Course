@Article{CarriereSwallow2013,
  Title                    = {The impact of uncertainty shocks in emerging economies},
  Author                   = {Carrière-Swallow, Yan and Céspedes, Luis Felipe},
  Journal                  = {Journal of International Economics},
  Year                     = {2013},
  Number                   = {2},
  Pages                    = {316-325},
  Volume                   = {90},

  Abstract                 = {A recent strand of research proposes that sudden jumps in uncertainty generate rapid drops and recoveries in real macroeconomic variables that drive the business cycle. Using an empirical model, we find substantial heterogeneity in reactions to these shocks across countries. In comparison to the U.S. and other developed countries, emerging economies suffer much more severe falls in investment and private consumption following an exogenous uncertainty shock, take significantly longer to recover, and do not experience a subsequent overshoot in activity. We provide evidence that the dynamics of investment and consumption are correlated with the depth of financial markets. We control for the potential role of a credit channel, and estimate that it can account for up to one-half of the increased fall in investment generated by uncertainty shocks among emerging economies with less-developed financial markets. In this context, monetary and fiscal policy actions that alleviate the impact of credit constraints facing firms may reduce the impact of uncertainty shocks in these economies.},
  Keywords                 = {Uncertainty; Emerging markets; Credit; Vector autoregression},
  Url                      = {https://ideas.repec.org/a/eee/inecon/v90y2013i2p316-325.html}
}

