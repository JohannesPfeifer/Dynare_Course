@Article{Rabin1993,
  Title                    = {Incorporating Fairness into Game Theory and Economics},
  Author                   = {Rabin, Matthew},
  Journal                  = {The American Economic Review},
  Year                     = {1993},
  Number                   = {5},
  Pages                    = {1281--1302},
  Volume                   = {83},

  Abstract                 = {People like to help those who are helping them, and to hurt those who are hurting them. Outcomes reflecting such motivations are called fairness equilibria. Outcomes are mutual-max when each person maximizes the other's material payoffs, and mutual-min when each person minimizes the other's payoffs. It is shown that every mutual-max or mutual-min Nash equilibrium is a fairness equilibrium. If payoffs are small, fairness equilibria are roughly the set of mutual-max and mutual-min outcomes; if payoffs are large, fairness equilibria are roughly the set of Nash equilibria. Several economic examples are considered, and possible welfare implications of fairness are explored.}
}

