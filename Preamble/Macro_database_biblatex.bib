@Article{CharemzaEtAl2022,
  author   = {Charemza, Wojciech and Makarova, Svetlana and Rybiński, Krzysztof},
  title    = {{Economic uncertainty and natural language processing; The case of Russia}},
  doi      = {10.1016/j.eap.2021.11.011},
