@Article{ErcegLinde2013,
  author    = {Erceg, Christopher and Jesper Lind\'e},
  title     = {Fiscal consolidation in a currency union: spending cuts vs. tax hikes},
  number    = {2},
  pages     = {422-445},
  url       = {http://ideas.repec.org/a/eee/dyncon/v37y2013i2p422-445.html},
  volume    = {37},
  abstract  = {This paper uses a two country DSGE model to examine the effects of
	tax-based vs. expenditure-based fiscal consolidation in a currency
	union. We find three key results. First, given limited scope for
	monetary accommodation, tax-based consolidation tends to have smaller
	adverse effects on output than expenditure-based consolidation in
	the near-term, though is more costly in the longer-run. Second, a
	large expenditure-based consolidation may be counterproductive in
	the near-term if the zero lower bound is binding, reflecting that
	output losses rise at the margin. Third, a â€œmixed strategyï¿½ï¿½? that
	combines a sharp but temporary rise in taxes with gradual spending
	cuts may be desirable in minimizing the output costs of fiscal consolidation.},
