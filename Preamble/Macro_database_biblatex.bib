@Article{Bhaskaretal2002JEP,
  Title                    = {Oligopsony and Monopsonistic Competition in Labor Markets},
  Author                   = {Bhaskar, V. and Manning, Alan and To, Ted},
  Journal                  = {The Journal of Economic Perspectives},
  Year                     = {2002},
  Number                   = {2},
  Pages                    = {155-174},
