@Article{Blanchard2000,
  author   = {Blanchard, Olivier J.},
  title    = {What Do We Know about Macroeconomics that Fisher and Wicksell Did Not?},
  year     = {2000},
  volume   = {115},
  number   = {4},
  pages    = {1375-1409},
  doi      = {10.1162/003355300554999},
  eprint   = {http://qje.oxfordjournals.org/content/115/4/1375.full.pdf+html},
  url      = {http://qje.oxfordjournals.org/content/115/4/1375.abstract},
  abstract = {This essay argues that the history of macroeconomics during the twentieth century can be divided into three epochs. Pre-1940: a period of exploration, during which all the right ingredients were developed. But also a period where confusion reigned, because of the lack of an integrated framework. From 1940 to 1980: a period during which an integrated framework was developed—from the IS-LM to dynamic general equilibrium models. But a construction with an Achilles'heel, too casual a treatment of imperfections, leading to a crisis in the late 1970s. Since 1980: a new period of exploration, focused on the role of imperfections in macroeconomics. Exploration often feels like confusion. But behind it is one of the most productive periods of research in macroeconomics.},
  journal  = {The Quarterly Journal of Economics},
}

