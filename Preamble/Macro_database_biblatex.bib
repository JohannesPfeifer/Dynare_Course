}

@TechReport{AghionBergeaudetal2017,
  author    = {Philippe Aghion and Antonin Bergeaud and Timo Boppart and Peter J. Klenow and Huiyu Li},
  title     = {{Missing Growth from Creative Destruction}},
  year      = {2017},
  type      = {NBER Working Papers},
  number    = {24023},
  month     = {11},
  url       = {https://ideas.repec.org/p/nbr/nberwo/24023.html},
  abstract  = {Statistical agencies typically impute inflation for disappearing products based on surviving products, which may result in overstated inflation and understated growth. Using U.S. Census data, we apply two ways of assessing the magnitude of \&quot;missing growth\&quot; for private nonfarm businesses from 1983-2013. The first approach exploits information on the market share of surviving plants. The second approach applies indirect inference to firm-level data. We find: (i) missing growth from imputation is substantial – at least 0.6 percentage points per year; and (ii) most of the missing growth is due to creative destruction (as opposed to new varieties).},
  timestamp = {2018-02-04},
}

