@Article{Ball1992,
  Title                    = {Why does high inflation raise inflation uncertainty?},
  Author                   = {Laurence Ball},
  Journal                  = {Journal of Monetary Economics},
  Year                     = {1992},
  Number                   = {3},
  Pages                    = {371-- 388},
  Volume                   = {29},

  Abstract                 = {This paper presents a model of monetary policy in which a rise in inflation raises uncertainty about future inflation. When actual and expected inflation are low, there is a consensus that the monetary authority will try to keep them low. When inflation is high, policymakers face a dilemma: they would like to disinflate, but fear the recession that would result. The public does not know the tastes of future policymakers, and thus does not know whether disinflation will occur.},
